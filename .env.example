# Django
SECRET_KEY=change-me-to-a-long-random-string
ENVIRONMENT=production
APP_VERSION=1.0.0

# PostgreSQL (Docker: POSTGRES_HOST=db | Local: POSTGRES_HOST=127.0.0.1)
POSTGRES_DB=firstgame
POSTGRES_USER=firstgame
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
REDIS_SESSIONS_URL=redis://redis:6379/1

# Optional
SENTRY_DSN=
CSRF_TRUSTED_ORIGINS=https://darabazaar.com,https://www.darabazaar.com
